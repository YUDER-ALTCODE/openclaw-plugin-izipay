# Izipay API Configuration
# Copy to .env and fill in your values

# Required: Izipay credentials
# Username: your Izipay user ID (e.g., 98671504)
IZIPAY_USERNAME=

# Password: test or production password from Izipay dashboard
IZIPAY_PASSWORD=

# Optional: Environment (default: sandbox)
# Values: sandbox | production
IZIPAY_ENVIRONMENT=sandbox
