{
  "id": "izipay",
  "name": "Izipay Payments",
  "description": "Integrate Izipay payment gateway for creating payments, checking status, and retrieving transaction details",
  "kind": "tool",
  "activation": {
    "onStartup": true
  },
  "setup": {
    "providers": [
      {
        "id": "izipay",
        "envVars": ["IZIPAY_USERNAME", "IZIPAY_PASSWORD"],
        "configFields": ["username", "password", "environment"]
      }
    ]
  },
  "uiHints": {
    "username": {
      "label": "Izipay Username",
      "help": "Izipay user ID (fallback: IZIPAY_USERNAME env var). Found in dashboard under Configuración → API Keys",
      "sensitive": false,
      "placeholder": "98671504"
    },
    "password": {
      "label": "Izipay Password",
      "help": "Izipay password (fallback: IZIPAY_PASSWORD env var). Use test password for sandbox, production password for live",
      "sensitive": true,
      "placeholder": "testpassword_..."
    },
    "environment": {
      "label": "Environment",
      "help": "Izipay environment to use",
      "options": [
        { "value": "sandbox", "label": "Sandbox (testing)" },
        { "value": "production", "label": "Production (live)" }
      ]
    }
  },
  "contracts": {
    "tools": [
      "izipay_create_payment",
      "izipay_payment_status",
      "izipay_payment_details"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "type": "string",
        "description": "Izipay user ID"
      },
      "password": {
        "type": "string",
        "description": "Izipay password (test or production)"
      },
      "environment": {
        "type": "string",
        "enum": ["sandbox", "production"],
        "default": "sandbox"
      }
    },
    "required": ["username", "password"]
  }
}
