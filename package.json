{
  "name": "@YUDER-ALTCODE/openclaw-plugin-izipay",
  "version": "0.1.1",
  "description": "OpenClaw plugin for Izipay payment gateway integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "openclaw plugins validate --entry ./dist/index.js",
    "prepublishOnly": "npm run plugin:build && npm run plugin:validate"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "izipay",
    "payments",
    "payment-gateway"
  ],
  "author": "Yuder Guerra <yuderguerra503@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YUDER-ALTCODE/openclaw-plugin-izipay.git"
  },
  "homepage": "https://github.com/YUDER-ALTCODE/openclaw-plugin-izipay#readme",
  "bugs": {
    "url": "https://github.com/YUDER-ALTCODE/openclaw-plugin-izipay/issues"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.0"
  },
  "dependencies": {
    "typebox": "^1.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.0",
      "minGatewayVersion": "2026.7.0"
    },
    "build": {
      "openclawVersion": "2026.7.0",
      "pluginSdkVersion": "2026.7.0"
    },
    "install": {
      "clawhubSpec": "clawhub:@YUDER-ALTCODE/openclaw-plugin-izipay",
      "npmSpec": "@YUDER-ALTCODE/openclaw-plugin-izipay",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.7.0"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
